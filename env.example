# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_TRUST_HOST=true

# 環境識別（UIに常時表示され、事故防止に使う）
# - local: ローカル開発（既定）
# - staging: 検証環境（既定でREAD ONLYに倒す）
# - production: 本番環境
MAILHUB_ENV=local

# Public URL（Slack通知などのMailHub直リンク生成に使用）
# MAILHUB_PUBLIC_BASE_URL=

# Google OAuth (used by NextAuth + Gmail API refresh)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared inbox (server-side only)
GOOGLE_SHARED_INBOX_EMAIL=inbox@vtj.co.jp
GOOGLE_SHARED_INBOX_REFRESH_TOKEN=

# Rakuten RMS API (optional - for in-app reply)
# If not set, RMS reply will fallback to opening RMS in browser
RMS_STORE_A_SHOP_ID=
RMS_STORE_A_SERVICE_SECRET=
RMS_STORE_A_LICENSE_KEY=
RMS_STORE_B_SHOP_ID=
RMS_STORE_B_SERVICE_SECRET=
RMS_STORE_B_LICENSE_KEY=
RMS_STORE_C_SHOP_ID=
RMS_STORE_C_SERVICE_SECRET=
RMS_STORE_C_LICENSE_KEY=

# Rakuten RMS Base URL (Step55: Reply Launcher)
# RMS問い合わせ画面へのdeep link URLのベース（例: https://rms.rakuten.co.jp）
# 未設定の場合は「RMSを開く」ボタンが無効化される
# MAILHUB_RAKUTEN_RMS_BASE_URL=https://rms.rakuten.co.jp

# Activity Store（永続化方式）
# - memory: メモリリングバッファ（既定、再起動で消える）
# - file: ローカルファイル（.mailhub/activity.jsonl、開発/CI用）
# - sheets: Google Sheets（本番推奨、再起動で消えない）
MAILHUB_ACTIVITY_STORE=memory

# Brain Decision Ledger（AI判断の永続証跡、Activityとは分離）
# - memory: メモリ（開発/TEST向け）
# - file: ローカルファイル（.mailhub/brainDecisions.jsonl）
# - sheets: Google Sheets（本番向け、MAILHUB_SHEETS_* が必要）
MAILHUB_BRAIN_LEDGER_STORE=memory
# Brain worker POST 認可（Authorization: Bearer <secret>）
# MAILHUB_BRAIN_SECRET=

# Google Sheets設定（MAILHUB_ACTIVITY_STORE=sheetsの場合に必要）
# MAILHUB_SHEETS_SPREADSHEET_ID=
# MAILHUB_SHEETS_CLIENT_EMAIL=
# MAILHUB_SHEETS_PRIVATE_KEY=
# MAILHUB_SHEETS_SHEET_NAME=

# Config Store（Settings: Labels/Rules 永続化方式）
# - memory: メモリ（TEST_MODE向け/一時）
# - file: ローカルファイル（.mailhub/*.json、開発/CI向け）
# - sheets: Google Sheets（staging/prod推奨）
MAILHUB_CONFIG_STORE=file

# Config Store Sheets（MAILHUB_CONFIG_STORE=sheets の場合）
# 既存の MAILHUB_SHEETS_SPREADSHEET_ID / MAILHUB_SHEETS_CLIENT_EMAIL / MAILHUB_SHEETS_PRIVATE_KEY を流用します。
# （別名で MAILHUB_SHEETS_ID も利用可能）
# MAILHUB_SHEETS_ID=
# MAILHUB_SHEETS_TAB_LABELS=
# MAILHUB_SHEETS_TAB_RULES=
# MAILHUB_SHEETS_TAB_ASSIGNEES=
# MAILHUB_SHEETS_TAB_ASSIGNEE_RULES=
# MAILHUB_SHEETS_TAB_TEMPLATES=
# MAILHUB_SHEETS_TAB_SAVED_SEARCHES=
# MAILHUB_SHEETS_TAB_VIEWS=
# MAILHUB_SHEETS_TAB_TEAM=
# MAILHUB_SHEETS_TAB_ROSTER=
# MAILHUB_SHEETS_TAB_NOTES=
# MAILHUB_SHEETS_TAB_META=
# MAILHUB_SHEETS_TAB_BRAIN_DECISIONS=

# Config health表示用（任意）
# MAILHUB_TEAM_MEMBERS=

# Admin Guard（Settingsの編集権限）
# カンマ区切りCSVで管理者メールを指定（未設定だと誰も編集できません）
# MAILHUB_ADMINS=

# READ ONLY（実データ接続の安全装置）
# - 1: 変更系APIを403で拒否し、UIも無効化（Preview/閲覧のみ）
# - 0: 通常モード（書き込み可能）
MAILHUB_READ_ONLY=1

# Gmail in-app send（不可逆な実メール送信のfeature flag）
# - 0 or unset: /api/mailhub/send を403で拒否
# - 1: READ ONLY解除、resolver、send-as accepted確認を通過した場合だけ送信可
MAILHUB_SEND_ENABLED=0

# MailHub routing probe sender（本番到達証跡用、通常アプリ送信とは別）
# - npm run probe:routing-send は既定で dry-run（送信しない）
# - --send 付き実行時のみ使用
# - MAILHUB_PROBE_FROM は @vtj.co.jp 以外の外部送信元を使うこと（@vtj.co.jp は内部GWS配送になり本番外部MX証跡にならない）
# MAILHUB_PROBE_SMTP_HOST=
# MAILHUB_PROBE_SMTP_PORT=587
# MAILHUB_PROBE_SMTP_SECURE=false
# MAILHUB_PROBE_SMTP_USER=
# MAILHUB_PROBE_SMTP_PASS=
# MAILHUB_PROBE_FROM=external-probe@example.com

# SLA Alerts（通知設定）
# - none: 通知無効（既定）
# - log: ログ出力のみ（テストモードでは自動的にlog）
# - slack: Slack webhook（本番推奨）
MAILHUB_ALERTS_PROVIDER=none
# MAILHUB_SLACK_WEBHOOK_URL=

# SLA Alerts認可（本番必須）
# production環境では必須。Authorization: Bearer <secret> で認可
# MAILHUB_ALERTS_SECRET=

# Config export (Step31)
# - GitHub Actions 等から Config（labels/rules）のバックアップを取得するためのsecret
# - productionでは Bearer認可で使用（Authorization: Bearer <secret>）
# - Export payloadには秘密情報は含まれません（labels/rulesのみ）
# MAILHUB_CONFIG_EXPORT_SECRET=

# Auto Rules Runner (Step53)
# - GitHub Actions 等から Auto Rules を定期実行するためのsecret
# - productionでは Bearer認可で使用（Authorization: Bearer <secret>）
# - test modeではスキップ（E2Eテスト用）
# MAILHUB_RULES_SECRET=

# Snooze Release Runner
# - GitHub Actions 等からSnooze期限到来分を解除するためのsecret
# - productionでは Bearer認可で使用（Authorization: Bearer <secret>）
# MAILHUB_SNOOZE_SECRET=

# TEST MODE（テスト専用。本番には設定しない）
# MAILHUB_TEST_MODE=
