# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Generate locally, for example: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_TRUST_HOST=true

# Environment marker shown in the UI and used for safety gates.
# - local: local development
# - staging: validation environment, usually read-only
# - production: production
MAILHUB_ENV=local

# Public URL used for MailHub deep links in notifications.
# MAILHUB_PUBLIC_BASE_URL=

# Google OAuth (used by NextAuth + Gmail API refresh)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared inbox (server-side only)
GOOGLE_SHARED_INBOX_EMAIL=inbox@vtj.co.jp
GOOGLE_SHARED_INBOX_REFRESH_TOKEN=

# Rakuten RMS API (optional - for in-app reply)
# If not set, RMS reply will fallback to opening RMS in browser.
RMS_STORE_A_SHOP_ID=
RMS_STORE_A_SERVICE_SECRET=
RMS_STORE_A_LICENSE_KEY=
RMS_STORE_B_SHOP_ID=
RMS_STORE_B_SERVICE_SECRET=
RMS_STORE_B_LICENSE_KEY=
RMS_STORE_C_SHOP_ID=
RMS_STORE_C_SERVICE_SECRET=
RMS_STORE_C_LICENSE_KEY=

# Rakuten RMS Base URL (Step55: Reply Launcher)
# MAILHUB_RAKUTEN_RMS_BASE_URL=https://rms.rakuten.co.jp

# Activity Store
# - memory: in-memory ring buffer, reset on restart
# - file: local file, for development/CI
# - sheets: Google Sheets, recommended for production
MAILHUB_ACTIVITY_STORE=memory

# Brain Decision Ledger
# - memory: local/test memory
# - file: local file
# - sheets: Google Sheets, requires MAILHUB_SHEETS_*
MAILHUB_BRAIN_LEDGER_STORE=memory
# MAILHUB_BRAIN_SECRET=

# Google Sheets settings, required when MAILHUB_ACTIVITY_STORE=sheets or MAILHUB_CONFIG_STORE=sheets.
# MAILHUB_SHEETS_SPREADSHEET_ID=
# MAILHUB_SHEETS_CLIENT_EMAIL=
# MAILHUB_SHEETS_PRIVATE_KEY=
# MAILHUB_SHEETS_SHEET_NAME=

# Config Store
# - memory: local/test memory
# - file: local file, for development/CI
# - sheets: Google Sheets, recommended for staging/production
MAILHUB_CONFIG_STORE=file

# Config Store Sheets. MAILHUB_SHEETS_ID is also accepted as an alias for MAILHUB_SHEETS_SPREADSHEET_ID.
# MAILHUB_SHEETS_ID=
# MAILHUB_SHEETS_TAB_LABELS=
# MAILHUB_SHEETS_TAB_RULES=
# MAILHUB_SHEETS_TAB_ASSIGNEES=
# MAILHUB_SHEETS_TAB_ASSIGNEE_RULES=
# MAILHUB_SHEETS_TAB_TEMPLATES=
# MAILHUB_SHEETS_TAB_SAVED_SEARCHES=
# MAILHUB_SHEETS_TAB_VIEWS=
# MAILHUB_SHEETS_TAB_TEAM=
# MAILHUB_SHEETS_TAB_ROSTER=
# MAILHUB_SHEETS_TAB_NOTES=
# MAILHUB_SHEETS_TAB_META=
# MAILHUB_SHEETS_TAB_BRAIN_DECISIONS=

# Staff access allowlists. Production values must be non-empty @vtj.co.jp email lists.
# MAILHUB_TEAM_MEMBERS=Staff <staff@vtj.co.jp>
# MAILHUB_ADMINS=Admin <admin@vtj.co.jp>

# READ ONLY safety gate
# - 1: reject write APIs and disable write UI
# - 0: normal write-enabled mode
MAILHUB_READ_ONLY=1

# Gmail in-app send feature flag
# - 0 or unset: /api/mailhub/send returns 403
# - 1: send is allowed only after READ ONLY, resolver, and send-as checks pass
MAILHUB_SEND_ENABLED=0

# MailHub routing probe sender. Use an external non-@vtj.co.jp sender for production proof.
# MAILHUB_PROBE_SMTP_HOST=
# MAILHUB_PROBE_SMTP_PORT=587
# MAILHUB_PROBE_SMTP_SECURE=false
# MAILHUB_PROBE_SMTP_USER=
# MAILHUB_PROBE_SMTP_PASS=
# MAILHUB_PROBE_FROM=external-probe@example.com

# SLA Alerts
# - none: disabled
# - log: log only
# - slack: Slack webhook
MAILHUB_ALERTS_PROVIDER=none
# MAILHUB_SLACK_WEBHOOK_URL=

# SLA Alerts authorization, required in production.
# MAILHUB_ALERTS_SECRET=

# Config export authorization secret.
# MAILHUB_CONFIG_EXPORT_SECRET=

# Auto Rules Runner authorization secret.
# MAILHUB_RULES_SECRET=

# Snooze Release Runner authorization secret.
# MAILHUB_SNOOZE_SECRET=

# TEST MODE, never set in production.
# MAILHUB_TEST_MODE=
